[Desktop Entry]
Type=Application
Name=Plumas Editor
GenericName=Text editor
Comment=Lightweight GTK4 text editor — developed by @PLUMAS_DEVELOPER@
Keywords=text;editor;notepad;markdown;code;plumas;
Exec=plumas-text-editor %F
Icon=plumas-text-editor
Terminal=false
Categories=Utility;TextEditor;
StartupWMClass=plumas-text-editor
MimeType=text/plain;text/markdown;text/x-markdown;text/x-chdr;text/x-csrc;text/x-c++src;text/x-python;text/x-java;text/x-sh;text/css;text/html;text/xml;text/x-sql;text/x-tex;text/x-log;application/json;application/xml;text/x-toml;text/x-yaml;text/x-ini;
StartupNotify=true
